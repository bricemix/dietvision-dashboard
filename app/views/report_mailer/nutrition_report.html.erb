<!DOCTYPE html>
<html lang="<%= @t[:lang] %>">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title>DietVision — <%= @subject %></title>
<style>
  body, table, td, p, a, h1, h2, h3 { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; }
  body { margin: 0; padding: 0; width: 100% !important; background: #f1f3ef; }
  table { border-collapse: collapse; mso-table-lspace: 0; mso-table-rspace: 0; }
  img { border: 0; display: block; outline: none; text-decoration: none; }
  a { text-decoration: none; }
  @media only screen and (max-width: 620px) {
    .container { width: 100% !important; max-width: 100% !important; }
    .px-pad { padding-left: 18px !important; padding-right: 18px !important; }
    .stack { display: block !important; width: 100% !important; }
    .stat-cell { display: inline-block !important; width: 47% !important; margin-bottom: 12px !important; }
    .meal-card { display: block !important; width: 100% !important; margin-bottom: 12px !important; }
    .action-card { display: block !important; width: 100% !important; margin-bottom: 10px !important; }
    h1.hero-title { font-size: 28px !important; line-height: 1.15 !important; }
  }
</style>
</head>
<body style="margin:0;padding:0;background:#f1f3ef;">

  <%# Preheader hidden %>
  <div style="display:none;font-size:1px;color:#f1f3ef;line-height:1px;max-height:0;max-width:0;opacity:0;overflow:hidden;">
    <%= @user.name %>, <%= @t[:greeting].downcase %> — <%= @meals_count %> <%= @t[:label_meals].downcase %><% if @latest_weight %>, <%= @latest_weight %> kg<% end %>
  </div>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f1f3ef;">
    <tr>
      <td align="center" style="padding:24px 12px;">
        <table role="presentation" class="container" width="600" cellpadding="0" cellspacing="0" border="0"
               style="width:600px;max-width:600px;background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 10px 30px rgba(0,0,0,0.06);">

          <%# ═══ HERO ═══ %>
          <tr>
            <td style="background:#0a0a0a;padding:36px 24px 32px;text-align:center;">
              <div style="font-size:38px;font-weight:800;letter-spacing:-0.5px;color:#ffffff;line-height:1;">
                <span style="color:#ffffff;">Diet</span><span style="color:#c8ff00;">Vision</span>
              </div>
              <div style="margin-top:14px;font-size:11px;letter-spacing:3px;color:rgba(255,255,255,0.55);font-weight:600;">
                <%= @frequency_label.upcase %> &middot; <%= @period_label %>
              </div>
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:14px auto 0;">
                <tr>
                  <td style="border:1.5px solid #c8ff00;border-radius:100px;padding:6px 22px;color:#c8ff00;font-size:11px;font-weight:800;letter-spacing:2px;">
                    ★ <%= @plan.name.upcase %>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <%# ═══ GREETING ═══ %>
          <tr>
            <td style="padding:28px 26px 16px;" class="px-pad">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td valign="top">
                    <p style="margin:0 0 6px;font-size:16px;color:#111;font-weight:500;">
                      <%= @t[:greeting] %> <strong><%= @user.name %></strong> 👋
                    </p>
                    <h1 class="hero-title" style="margin:0 0 14px;font-size:32px;line-height:1.1;font-weight:800;letter-spacing:-0.8px;color:#111;">
                      <%= @t[:subtitle_balanced].split('—').first.strip if @kcal_status == :balanced %>
                      <%= @t[:subtitle_default].split('.').first if @kcal_status != :balanced %>
                    </h1>
                    <p style="margin:0;font-size:13px;color:#6b6b6b;line-height:1.6;max-width:380px;">
                      <% if @meals_count == 0 %>
                        <%= @t[:subtitle_no_meals] %>
                      <% else %>
                        <%= @t[:subtitle_balanced] if @kcal_status == :balanced %>
                        <%= @t[:subtitle_deficit]  if @kcal_status == :deficit %>
                        <%= @t[:subtitle_surplus]  if @kcal_status == :surplus %>
                        <%= @t[:subtitle_default]  if @kcal_status == :unknown %>
                      <% end %>
                    </p>
                  </td>
                  <td valign="top" width="120" align="right" style="padding-left:8px;">
                    <svg width="110" height="110" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="80" cy="40" r="36" fill="#e8ffa8" opacity="0.4"/>
                      <g transform="translate(60 60) rotate(35)">
                        <path d="M -6 -28 Q 0 -38 6 -28 L 6 6 L -6 6 Z" fill="#1a1a1a"/>
                        <circle cx="0" cy="-15" r="4" fill="#c8ff00"/>
                        <path d="M -6 -2 L -12 8 L -6 6 Z" fill="#c8ff00"/>
                        <path d="M 6 -2 L 12 8 L 6 6 Z" fill="#c8ff00"/>
                        <path d="M -4 6 Q 0 22 4 6 Z" fill="#c8ff00"/>
                        <path d="M -2 6 Q 0 16 2 6 Z" fill="#ffffff"/>
                      </g>
                      <text x="98" y="22" font-size="10" fill="#c8ff00">✦</text>
                      <text x="108" y="48" font-size="8" fill="#c8ff00">✦</text>
                    </svg>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <%# ═══ 1. ACTIONS RECOMMANDÉES ═══ %>
          <tr>
            <td style="padding:20px 26px 4px;" class="px-pad">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#0a0a0a;border-radius:18px;">
                <tr>
                  <td style="padding:20px 18px 18px;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td valign="middle" width="38" style="padding-right:8px;">
                          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c8ff00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2" fill="#c8ff00"/></svg>
                        </td>
                        <td valign="middle">
                          <p style="margin:0 0 2px;font-size:15px;font-weight:800;color:#fff;">1. <%= @t[:action_title] || "Votre prochaine action recommandée" %></p>
                          <p style="margin:0;font-size:12px;color:rgba(255,255,255,0.45);"><%= @t[:action_subtitle] || "Agissez maintenant pour continuer à progresser." %></p>
                        </td>
                      </tr>
                    </table>
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:14px;">
                      <tr>
                        <td valign="top" class="action-card" style="width:33%;padding-right:5px;">
                          <a href="<%= @url_scan %>" style="display:block;text-decoration:none;">
                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#c8ff00;border-radius:14px;height:110px;">
                              <tr>
                                <td style="padding:12px;vertical-align:top;">
                                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                                  <p style="margin:8px 0 2px;font-size:13px;color:#000;font-weight:800;line-height:1.2;"><%= @t[:action_scan] || "Scanner mon<br>prochain repas" %></p>
                                  <span style="display:inline-block;margin-top:6px;background:rgba(0,0,0,0.12);border-radius:100px;padding:2px 8px;font-size:9px;color:#000;font-weight:700;"><%= @t[:action_main] || "Action principale" %></span>
                                </td>
                                <td valign="top" align="right" style="padding:12px;"><span style="color:#000;font-size:18px;font-weight:800;">›</span></td>
                              </tr>
                            </table>
                          </a>
                        </td>
                        <td valign="top" class="action-card" style="width:33%;padding:0 5px;">
                          <a href="<%= @url_measures %>" style="display:block;text-decoration:none;">
                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#161616;border-radius:14px;height:110px;border:1px solid rgba(200,255,0,0.15);">
                              <tr>
                                <td style="padding:12px;vertical-align:top;">
                                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c8ff00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><line x1="9" y1="4" x2="9" y2="20"/><line x1="15" y1="4" x2="15" y2="20"/></svg>
                                  <p style="margin:18px 0 0;font-size:13px;color:#fff;font-weight:700;line-height:1.2;"><%= @t[:action_measures] || "Ajouter<br>mes mesures" %></p>
                                </td>
                                <td valign="top" align="right" style="padding:12px;"><span style="color:#c8ff00;font-size:18px;font-weight:800;">›</span></td>
                              </tr>
                            </table>
                          </a>
                        </td>
                        <td valign="top" class="action-card" style="width:33%;padding-left:5px;">
                          <a href="<%= @url_coach %>" style="display:block;text-decoration:none;">
                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#161616;border-radius:14px;height:110px;border:1px solid rgba(200,255,0,0.15);">
                              <tr>
                                <td style="padding:12px;vertical-align:top;">
                                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c8ff00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="8" width="14" height="12" rx="3"/><circle cx="9" cy="13" r="1.2" fill="#c8ff00"/><circle cx="15" cy="13" r="1.2" fill="#c8ff00"/><line x1="9" y1="17" x2="15" y2="17"/><line x1="12" y1="4" x2="12" y2="8"/></svg>
                                  <p style="margin:18px 0 0;font-size:13px;color:#fff;font-weight:700;line-height:1.2;"><%= @t[:action_coach] || "Parler au<br>coach IA" %></p>
                                </td>
                                <td valign="top" align="right" style="padding:12px;"><span style="color:#c8ff00;font-size:18px;font-weight:800;">›</span></td>
                              </tr>
                            </table>
                          </a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <%# ═══ 2. CHIFFRES CLÉS ═══ %>
          <tr>
            <td style="padding:24px 26px 6px;" class="px-pad">
              <p style="margin:0 0 14px;font-size:18px;font-weight:800;color:#111;letter-spacing:-0.2px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5a9a1f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-3px;display:inline-block"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/></svg>
                &nbsp;&nbsp;2. <%= @t[:section_key_stats] %>
              </p>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td valign="top" class="stat-cell" style="width:25%;padding-right:6px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#fafbf6;border:1px solid #ecefe2;border-radius:14px;text-align:center;">
                      <tr><td style="padding:14px 8px;">
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center"><tr>
                          <td style="background:#e3f5c8;width:44px;height:44px;border-radius:50%;text-align:center;vertical-align:middle;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5a9a1f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;"><path d="M3 2v8a4 4 0 0 0 4 4h0a4 4 0 0 0 4-4V2"/><line x1="7" y1="2" x2="7" y2="22"/><path d="M15 8c0-2 1-6 3-6v20"/></svg>
                          </td>
                        </tr></table>
                        <p style="margin:8px 0 0;font-size:26px;font-weight:800;color:#111;line-height:1;"><%= @meals_count %></p>
                        <p style="margin:4px 0 0;font-size:11px;font-weight:600;color:#444;"><%= @t[:label_meals] %></p>
                      </td></tr>
                    </table>
                  </td>
                  <td valign="top" class="stat-cell" style="width:25%;padding:0 3px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#fafbf6;border:1px solid #ecefe2;border-radius:14px;text-align:center;">
                      <tr><td style="padding:14px 8px;">
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center"><tr>
                          <td style="background:#ffe9d0;width:44px;height:44px;border-radius:50%;text-align:center;vertical-align:middle;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="#ff9b3a" style="vertical-align:middle;"><path d="M13.5 0c-.83 0-1.5.67-1.5 1.5 0 .91-1.13 2.06-2.17 3.06C8.3 6.13 6 8.31 6 12c0 3.31 2.69 6 6 6s6-2.69 6-6c0-3.69-2.3-5.87-3.83-7.44z"/></svg>
                          </td>
                        </tr></table>
                        <p style="margin:8px 0 0;font-size:26px;font-weight:800;color:#111;line-height:1;"><%= number_with_delimiter(@avg_kcal_day) %></p>
                        <p style="margin:4px 0 0;font-size:11px;font-weight:600;color:#444;"><%= @t[:label_kcal] %></p>
                        <% if @kcal_status == :balanced %>
                          <p style="margin:2px 0 0;font-size:10px;color:#5a9a1f;font-weight:600;">✓ <%= @t[:kcal_balanced].gsub('✅ ','') %></p>
                        <% end %>
                      </td></tr>
                    </table>
                  </td>
                  <td valign="top" class="stat-cell" style="width:25%;padding:0 3px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#fafbf6;border:1px solid #ecefe2;border-radius:14px;text-align:center;">
                      <tr><td style="padding:14px 8px;">
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center"><tr>
                          <td style="background:#e7ddff;width:44px;height:44px;border-radius:50%;text-align:center;vertical-align:middle;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7c5fd3" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;"><rect x="4" y="4" width="16" height="16" rx="3"/><text x="12" y="16" text-anchor="middle" font-size="10" font-weight="800" fill="#7c5fd3" stroke="none">A</text></svg>
                          </td>
                        </tr></table>
                        <p style="margin:8px 0 0;font-size:26px;font-weight:800;color:#111;line-height:1;"><%= @ai_analyses %></p>
                        <p style="margin:4px 0 0;font-size:11px;font-weight:600;color:#444;"><%= @t[:label_ai] %></p>
                      </td></tr>
                    </table>
                  </td>
                  <td valign="top" class="stat-cell" style="width:25%;padding-left:6px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#fafbf6;border:1px solid #ecefe2;border-radius:14px;text-align:center;">
                      <tr><td style="padding:14px 8px;">
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center"><tr>
                          <td style="background:#d9eaff;width:44px;height:44px;border-radius:50%;text-align:center;vertical-align:middle;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4a8ee0" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                          </td>
                        </tr></table>
                        <p style="margin:8px 0 0;font-size:26px;font-weight:800;color:#111;line-height:1;"><%= @ai_coach %></p>
                        <p style="margin:4px 0 0;font-size:11px;font-weight:600;color:#444;"><%= @t[:label_coach] %></p>
                      </td></tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <%# ═══ 3. REPAS RÉCENTS ═══ %>
          <% if @top_meals.any? %>
          <tr>
            <td style="padding:22px 26px 4px;" class="px-pad">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td><p style="margin:0;font-size:18px;font-weight:800;color:#111;letter-spacing:-0.2px;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5a9a1f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-3px;display:inline-block"><path d="M3 2v8a4 4 0 0 0 4 4v8"/><line x1="7" y1="2" x2="7" y2="10"/><path d="M11 2v8a4 4 0 0 1-4 4"/><path d="M17 2c-2 0-3 2-3 5v6h3v9"/></svg>
                    &nbsp;&nbsp;3. <%= @t[:section_top_meals] %>
                  </p></td>
                  <td align="right"><p style="margin:0;font-size:11px;color:#888;">★ <strong style="color:#111;"><%= @best_meal %></strong></p></td>
                </tr>
              </table>

              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:12px;">
                <tr>
                  <% @top_meals.first(3).each_with_index do |meal, idx| %>
                    <% result = meal['result'] || {} %>
                    <% padding = idx == 0 ? "padding-right:6px" : idx == @top_meals.first(3).size - 1 ? "padding-left:6px" : "padding:0 3px" %>
                    <td valign="top" class="meal-card" style="width:33%;<%= padding %>">
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#fafbf6;border:1px solid #ecefe2;border-radius:14px;">
                        <tr>
                          <td valign="top" width="60" style="padding:10px 6px 10px 10px;">
                            <% if meal['thumbnailBase64'].present? %>
                              <img src="data:image/jpeg;base64,<%= meal['thumbnailBase64'] %>"
                                   style="width:60px;height:60px;border-radius:10px;object-fit:cover;" alt="">
                            <% else %>
                              <div style="width:60px;height:60px;background:linear-gradient(135deg,#f3e7c8,#d4a574);border-radius:10px;text-align:center;vertical-align:middle;display:table-cell;">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#7a4d18" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle"><path d="M4 14h16M5 14a7 7 0 0 1 14 0"/><path d="M2 18h20"/></svg>
                              </div>
                            <% end %>
                          </td>
                          <td valign="top" style="padding:10px 10px 10px 4px;">
                            <p style="margin:5px 0 1px;font-size:13px;font-weight:700;color:#111;line-height:1.2;"><%= result['name'] || '—' %></p>
                            <p style="margin:0 0 4px;font-size:13px;font-weight:800;color:#111;"><%= result['calories'] || 0 %> <span style="font-size:10px;font-weight:500;color:#888;">kcal</span></p>
                            <p style="margin:0;font-size:10px;color:#888;">
                              <span style="color:#a78bfa;">P</span> <%= result['protein']&.round || 0 %>g &middot;
                              <span style="color:#4a8ee0;">G</span> <%= result['carbs']&.round || 0 %>g &middot;
                              <span style="color:#ff9b3a;">L</span> <%= result['fat']&.round || 0 %>g
                            </p>
                          </td>
                        </tr>
                      </table>
                    </td>
                  <% end %>
                </tr>
              </table>
            </td>
          </tr>
          <% end %>

          <%# ═══ 4 & 5 — MACROS DONUT + BODY ═══ %>
          <tr>
            <td style="padding:22px 26px 4px;" class="px-pad">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <%# 4. NUTRITION DONUT %>
                  <td valign="top" class="stack" style="width:50%;padding-right:6px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#fafbf6;border:1px solid #ecefe2;border-radius:18px;">
                      <tr><td style="padding:16px 14px;">
                        <p style="margin:0 0 2px;font-size:15px;font-weight:800;color:#111;letter-spacing:-0.2px;">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5a9a1f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-3px;display:inline-block"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg>
                          &nbsp;4. <%= @t[:section_macros] %>
                        </p>
                        <% if @meals_count > 0 && @prot_pct > 0 %>
                          <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin-top:10px;">
                            <tr>
                              <td valign="middle" width="120" align="center">
                                <svg width="120" height="120" viewBox="0 0 120 120">
                                  <circle cx="60" cy="60" r="44" fill="none" stroke="#ecefe2" stroke-width="14"/>
                                  <circle cx="60" cy="60" r="44" fill="none" stroke="#a78bfa" stroke-width="14"
                                          stroke-dasharray="<%= @prot_dash %> 276.46"
                                          transform="rotate(-90 60 60)"/>
                                  <circle cx="60" cy="60" r="44" fill="none" stroke="#4a8ee0" stroke-width="14"
                                          stroke-dasharray="<%= @carbs_dash %> 276.46"
                                          stroke-dashoffset="<%= @carbs_offset %>"
                                          transform="rotate(-90 60 60)"/>
                                  <circle cx="60" cy="60" r="44" fill="none" stroke="#ff9b3a" stroke-width="14"
                                          stroke-dasharray="<%= @fat_dash %> 276.46"
                                          stroke-dashoffset="<%= @fat_offset %>"
                                          transform="rotate(-90 60 60)"/>
                                  <text x="60" y="58" text-anchor="middle" font-size="17" font-weight="800" fill="#111"><%= number_with_delimiter(@avg_kcal_day) %></text>
                                  <text x="60" y="72" text-anchor="middle" font-size="9" fill="#888"><%= @t[:kcal_day] %></text>
                                </svg>
                              </td>
                              <td valign="middle" style="padding-left:8px;">
                                <p style="margin:0 0 6px;font-size:12px;color:#111;"><span style="display:inline-block;width:9px;height:9px;background:#a78bfa;border-radius:50%;vertical-align:middle;"></span> &nbsp;<%= @t[:macro_protein] %> <strong><%= @prot_pct %>%</strong></p>
                                <p style="margin:0 0 6px;font-size:12px;color:#111;"><span style="display:inline-block;width:9px;height:9px;background:#4a8ee0;border-radius:50%;vertical-align:middle;"></span> &nbsp;<%= @t[:macro_carbs] %> <strong><%= @carbs_pct %>%</strong></p>
                                <p style="margin:0;font-size:12px;color:#111;"><span style="display:inline-block;width:9px;height:9px;background:#ff9b3a;border-radius:50%;vertical-align:middle;"></span> &nbsp;<%= @t[:macro_fat] %> <strong><%= @fat_pct %>%</strong></p>
                              </td>
                            </tr>
                          </table>
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:12px;">
                            <tr>
                              <td valign="top" style="padding:8px 4px;background:#f3f0ff;border-radius:10px;text-align:center;width:33%;">
                                <p style="margin:0;font-size:9px;color:#888;"><%= @t[:macro_protein] %></p>
                                <p style="margin:2px 0 0;font-size:13px;font-weight:800;color:#111;"><%= @total_protein.round %>g</p>
                              </td>
                              <td style="width:6px;"></td>
                              <td valign="top" style="padding:8px 4px;background:#eef4ff;border-radius:10px;text-align:center;width:33%;">
                                <p style="margin:0;font-size:9px;color:#888;"><%= @t[:macro_carbs] %></p>
                                <p style="margin:2px 0 0;font-size:13px;font-weight:800;color:#111;"><%= @total_carbs.round %>g</p>
                              </td>
                              <td style="width:6px;"></td>
                              <td valign="top" style="padding:8px 4px;background:#fff4e6;border-radius:10px;text-align:center;width:33%;">
                                <p style="margin:0;font-size:9px;color:#888;"><%= @t[:macro_fat] %></p>
                                <p style="margin:2px 0 0;font-size:13px;font-weight:800;color:#111;"><%= @total_fat.round %>g</p>
                              </td>
                            </tr>
                          </table>
                        <% else %>
                          <p style="margin:12px 0 0;font-size:12px;color:#aaa;"><%= @t[:no_meals] %></p>
                        <% end %>
                      </td></tr>
                    </table>
                  </td>

                  <%# 5. BODY PROGRESSION %>
                  <td valign="top" class="stack" style="width:50%;padding-left:6px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#fafbf6;border:1px solid #ecefe2;border-radius:18px;">
                      <tr><td style="padding:16px 14px;">
                        <p style="margin:0 0 2px;font-size:15px;font-weight:800;color:#111;letter-spacing:-0.2px;">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5a9a1f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-3px;display:inline-block"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                          &nbsp;5. <%= @t[:section_body] %>
                        </p>
                        <% if @weight_checkpoints.any? %>
                          <%# Mini graphe poids %>
                          <% pts = @weight_checkpoints %>
                          <% weights = pts.map { |e| e['weight'].to_f } %>
                          <% w_min = weights.min; w_max = weights.max; w_range = [w_max - w_min, 0.1].max %>
                          <% chart_w = 240; chart_h = 80 %>
                          <svg width="100%" height="80" viewBox="0 0 <%= chart_w %> <%= chart_h %>" preserveAspectRatio="none" style="margin:10px 0;">
                            <line x1="0" y1="<%= chart_h * 0.2 %>" x2="<%= chart_w %>" y2="<%= chart_h * 0.2 %>" stroke="#ecefe2" stroke-width="1"/>
                            <line x1="0" y1="<%= chart_h * 0.6 %>" x2="<%= chart_w %>" y2="<%= chart_h * 0.6 %>" stroke="#ecefe2" stroke-width="1"/>
                            <% pts.each_with_index do |e, i| %>
                              <% x = pts.size == 1 ? chart_w / 2 : (i.to_f / (pts.size - 1) * (chart_w - 40) + 20).round %>
                              <% y = (chart_h * 0.8 - ((e['weight'].to_f - w_min) / w_range) * (chart_h * 0.6)).round %>
                              <% if i > 0 %>
                                <% prev = pts[i-1]; px = pts.size == 1 ? chart_w/2 : ((i-1).to_f / (pts.size-1) * (chart_w-40) + 20).round; py = (chart_h*0.8 - ((prev['weight'].to_f - w_min)/w_range)*(chart_h*0.6)).round %>
                                <line x1="<%= px %>" y1="<%= py %>" x2="<%= x %>" y2="<%= y %>" stroke="#5a9a1f" stroke-width="2.5"/>
                              <% end %>
                              <circle cx="<%= x %>" cy="<%= y %>" r="4" fill="#5a9a1f"/>
                              <text x="<%= x %>" y="<%= [y - 6, 10].max %>" text-anchor="middle" font-size="9" font-weight="700" fill="#111"><%= e['weight'] %></text>
                              <text x="<%= x %>" y="<%= chart_h - 2 %>" text-anchor="middle" font-size="8" fill="#888"><%= Date.parse(e['date'].to_s).strftime("%-d %b") rescue '' %></text>
                            <% end %>
                          </svg>
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td valign="top" style="padding:8px;background:#f3f0ff;border-radius:10px;width:48%;">
                                <p style="margin:0;font-size:9px;color:#888;"><%= @t[:body_weight] %></p>
                                <p style="margin:2px 0;font-size:13px;font-weight:800;color:#111;"><%= @latest_weight %> kg</p>
                                <% if @weight_delta %>
                                  <p style="margin:0;font-size:9px;color:<%= @weight_delta < 0 ? '#5a9a1f' : '#dc2626' %>;font-weight:700;">
                                    <%= @weight_delta > 0 ? '+' : '' %><%= @weight_delta %> kg
                                  </p>
                                <% end %>
                              </td>
                              <td style="width:4px;"></td>
                              <% if @tdee > 0 %>
                              <td valign="top" style="padding:8px;background:#e8ffb8;border-radius:10px;width:48%;">
                                <p style="margin:0;font-size:9px;color:#888;"><%= @t[:body_tdee] %></p>
                                <p style="margin:2px 0;font-size:13px;font-weight:800;color:#111;"><%= number_with_delimiter(@tdee) %> <%= @t[:kcal_day] %></p>
                                <p style="margin:0;font-size:9px;color:#3d6b1f;font-weight:700;"><%= @t[:body_goal] %> : <%= @goal %></p>
                              </td>
                              <% end %>
                            </tr>
                          </table>
                        <% else %>
                          <p style="margin:12px 0 0;font-size:12px;color:#aaa;"><%= @t[:body_no_data] %></p>
                        <% end %>
                      </td></tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <%# ═══ 6. OBJECTIF & COHÉRENCE ═══ %>
          <% if @kcal_status != :unknown && @target_kcal > 0 %>
          <tr>
            <td style="padding:22px 26px 4px;" class="px-pad">
              <p style="margin:0 0 12px;font-size:18px;font-weight:800;color:#111;letter-spacing:-0.2px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5a9a1f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-3px;display:inline-block"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2" fill="#5a9a1f"/></svg>
                &nbsp;&nbsp;6. <%= @t[:section_objective] || "Objectif & cohérence" %>
              </p>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#fafbf6;border:1px solid #ecefe2;border-radius:14px;">
                <tr>
                  <td valign="middle" class="stack" style="padding:14px 16px;width:60%;">
                    <p style="margin:0 0 6px;font-size:13px;color:#111;">
                      <%= @t[:kcal_balanced] if @kcal_status == :balanced %>
                      <%= @t[:kcal_deficit].gsub('💙 ','') + " #{@kcal_diff} #{@t[:kcal_day]}" if @kcal_status == :deficit %>
                      <%= @t[:kcal_surplus].gsub('🟠 ','') + " #{@kcal_diff} #{@t[:kcal_day]}" if @kcal_status == :surplus %>
                    </p>
                    <% pct_in_target = @kcal_status == :balanced ? 100 : [@kcal_status == :deficit ? 70 : 40, 100].min %>
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="background:#ecefe2;border-radius:100px;height:8px;overflow:hidden;">
                          <div style="background:<%= @kcal_status == :balanced ? '#c8ff00' : '#ff9b3a' %>;width:<%= pct_in_target %>%;height:8px;border-radius:100px;"></div>
                        </td>
                      </tr>
                    </table>
                  </td>
                  <td valign="top" class="stack" style="padding:14px 16px;width:40%;background:#e8ffb8;border-left:1px solid #ecefe2;border-radius:0 14px 14px 0;">
                    <p style="margin:0;font-size:11px;color:#3d6b1f;line-height:1.5;">
                      <%= @t[:kcal_text_balanced] if @kcal_status == :balanced %>
                      <%= @t[:kcal_text_deficit]  if @kcal_status == :deficit %>
                      <%= @t[:kcal_text_surplus]  if @kcal_status == :surplus %>
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <% end %>

          <%# ═══ 7. CONSEIL DIETVISION ═══ %>
          <tr>
            <td style="padding:22px 26px 8px;" class="px-pad">
              <p style="margin:0 0 10px;font-size:18px;font-weight:800;color:#111;letter-spacing:-0.2px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5a9a1f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-3px;display:inline-block"><path d="M9 2h6a2 2 0 0 1 2 2v0a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2v0a2 2 0 0 1 2-2z"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg>
                &nbsp;&nbsp;7. <%= @t[:tip_label] %>
              </p>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f4ffd6;border:1px solid #c8ff00;border-radius:14px;">
                <tr>
                  <td valign="middle" width="60" style="padding:12px 4px 12px 14px;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="background:#c8ff00;width:44px;height:44px;border-radius:50%;text-align:center;vertical-align:middle;">
                          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;display:inline-block"><polyline points="20 6 9 17 4 12"/></svg>
                        </td>
                      </tr>
                    </table>
                  </td>
                  <td valign="middle" style="padding:12px 14px 12px 8px;">
                    <p style="margin:0;font-size:13px;color:#111;line-height:1.5;"><%= @report_tip %></p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <%# ═══ CTA ═══ %>
          <tr>
            <td align="center" style="padding:28px 26px 8px;" class="px-pad">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="background:#c8ff00;border-radius:100px;">
                    <a href="<%= @url_app %>" style="display:inline-block;padding:14px 36px;font-size:15px;font-weight:800;color:#111;text-decoration:none;letter-spacing:-0.2px;">
                      <%= @t[:cta] %> &nbsp;›
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <%# ═══ FOOTER ═══ %>
          <tr>
            <td style="padding:18px 26px 30px;border-top:1px solid #ecefe2;text-align:center;" class="px-pad">
              <p style="margin:8px 0 0;font-size:12px;color:#666;">
                ✉ &nbsp;<%= @t[:questions] %>
                <a href="mailto:<%= AppConfig.get('support_email') %>" style="color:#4a8ee0;font-weight:600;"><%= AppConfig.get('support_email') %></a>
              </p>
              <p style="margin:14px 0 0;font-size:11px;color:#999;line-height:1.6;">
                <%= @t[:footer_prefix] %> <strong><%= @plan.name %></strong> <%= @t[:footer_suffix] %>
              </p>
              <p style="margin:6px 0 0;font-size:11px;color:#999;">
                &copy; <%= Date.current.year %> DietVision &nbsp;&middot;&nbsp;
                <a href="<%= @url_app %>" style="color:#4a8ee0;font-weight:600;">dietvision.app</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
