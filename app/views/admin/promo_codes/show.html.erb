<% content_for :title, "Code #{@promo_code.code}" %>

<div class="mb-6">
  <%= link_to "← Retour aux codes promo", admin_promo_codes_path, class: "text-xs text-gray-500 hover:text-gray-300" %>
</div>

<div class="mb-6 flex items-center justify-between gap-4">
  <div>
    <h1 class="text-xl font-bold text-white font-mono tracking-wider"><%= @promo_code.code %></h1>
    <div class="text-xs text-gray-500 mt-1">
      <%= @promo_code.discount_label %> ·
      <span class="text-xs font-semibold px-2 py-0.5 rounded-full
        <%= @promo_code.effective_status == 'active' ? 'bg-green-900/40 text-green-400' :
            @promo_code.effective_status == 'expired' ? 'bg-yellow-900/30 text-yellow-500' :
            'bg-red-900/30 text-red-400' %>">
        <%= @promo_code.effective_status.upcase %>
      </span>
    </div>
  </div>
  <div class="flex gap-6 text-center">
    <div>
      <div class="text-2xl font-bold text-white"><%= @promo_code.uses_count %></div>
      <div class="text-[10px] text-gray-500 uppercase tracking-wide">Utilisations
        <%= @promo_code.max_uses_total ? "/ #{@promo_code.max_uses_total}" : "" %>
      </div>
    </div>
    <div>
      <div class="text-2xl font-bold lime"><%= @unique_users %></div>
      <div class="text-[10px] text-gray-500 uppercase tracking-wide">Utilisateurs uniques</div>
    </div>
  </div>
</div>

<div class="bg-gray-900 rounded-xl border border-gray-800 overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-800 text-xs text-gray-500 uppercase tracking-wide">
        <th class="text-left px-5 py-3 font-medium">Utilisateur</th>
        <th class="text-left px-4 py-3 font-medium">Email</th>
        <th class="text-left px-4 py-3 font-medium">Paiement lié</th>
        <th class="text-left px-4 py-3 font-medium">Date d'utilisation</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-800">
      <% @redemptions.each do |r| %>
        <tr class="hover:bg-gray-800/40 transition-colors">
          <td class="px-5 py-3">
            <%= link_to r.user.name, admin_user_path(r.user), class: "text-white hover:underline" %>
          </td>
          <td class="px-4 py-3 text-gray-400"><%= r.user.email %></td>
          <td class="px-4 py-3 text-xs text-gray-500">
            <% if r.payment %>
              <%= r.payment.amount.to_f / 100 %> <%= r.payment.currency %> · <%= r.payment.status %>
            <% else %>
              <span class="text-gray-700">—</span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-xs text-gray-400"><%= r.created_at.strftime("%d/%m/%Y %H:%M") %></td>
        </tr>
      <% end %>
      <% if @redemptions.empty? %>
        <tr><td colspan="4" class="px-5 py-10 text-center text-gray-600">Ce code n'a encore été utilisé par personne</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
