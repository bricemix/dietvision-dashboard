<%# Shared form for PromoCode %>

<div class="bg-gray-900 rounded-xl border border-gray-800 p-6 max-w-xl">
  <%= form_with model: [:admin, promo_code], class: "space-y-4" do |f| %>

    <% if promo_code.errors.any? %>
      <div class="p-3 bg-red-950 border border-red-800 rounded-lg text-red-400 text-sm">
        <%= promo_code.errors.full_messages.join(" · ") %>
      </div>
    <% end %>

    <%# Code %>
    <div>
      <%= f.label :code, "Code promo", class: "block text-xs font-medium text-gray-400 mb-1" %>
      <%= f.text_field :code, placeholder: "NOVALAB20",
            class: "w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white font-mono uppercase placeholder-gray-600 focus:outline-none focus:border-gray-500" %>
    </div>

    <%# Réduction %>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <%= f.label :discount_type, "Type de réduction", class: "block text-xs font-medium text-gray-400 mb-1" %>
        <%= f.select :discount_type,
              [["Pourcentage (%)", "percent"], ["Montant fixe (Ar)", "fixed"]],
              { selected: promo_code.discount_type },
              class: "w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white focus:outline-none focus:border-gray-500" %>
      </div>
      <div>
        <%= f.label :discount_value, "Valeur", class: "block text-xs font-medium text-gray-400 mb-1" %>
        <%= f.number_field :discount_value, min: 1, step: 1,
              class: "w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white focus:outline-none focus:border-gray-500" %>
      </div>
    </div>

    <%# Plans applicables %>
    <div>
      <label class="block text-xs font-medium text-gray-400 mb-2">Plans auxquels ce code s'applique</label>
      <div class="flex flex-wrap gap-2">
        <% Plan.order(:position).each do |p| %>
          <label class="flex items-center gap-2 px-3 py-1.5 bg-gray-800 rounded-lg cursor-pointer border border-gray-700 hover:border-gray-600 transition-colors">
            <input type="checkbox" name="promo_code[applicable_plans][]" value="<%= p.slug %>"
                   <%= promo_code.applicable_plans.include?(p.slug) ? "checked" : "" %>
                   class="accent-lime-400 w-3.5 h-3.5">
            <span class="text-sm text-gray-300"><%= p.name %></span>
          </label>
        <% end %>
        <% if Plan.none? %>
          <span class="text-xs text-gray-600">Créez d'abord des plans</span>
        <% end %>
        <label class="flex items-center gap-2 px-3 py-1.5 bg-gray-800 rounded-lg cursor-pointer border border-gray-700 hover:border-gray-600 transition-colors">
          <input type="checkbox" name="promo_code[applicable_plans][]" value="all"
                 <%= promo_code.applicable_plans.include?("all") ? "checked" : "" %>
                 class="accent-lime-400 w-3.5 h-3.5">
          <span class="text-sm text-gray-300">Tous les plans</span>
        </label>
      </div>
    </div>

    <%# Dates %>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <%= f.label :starts_at, "Date de début (optionnel)", class: "block text-xs font-medium text-gray-400 mb-1" %>
        <%= f.datetime_local_field :starts_at,
              value: promo_code.starts_at&.strftime("%Y-%m-%dT%H:%M"),
              class: "w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white focus:outline-none focus:border-gray-500" %>
      </div>
      <div>
        <%= f.label :expires_at, "Date d'expiration (optionnel)", class: "block text-xs font-medium text-gray-400 mb-1" %>
        <%= f.datetime_local_field :expires_at,
              value: promo_code.expires_at&.strftime("%Y-%m-%dT%H:%M"),
              class: "w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white focus:outline-none focus:border-gray-500" %>
      </div>
    </div>

    <%# Limites d'utilisation %>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <%= f.label :max_uses_total, "Nb max d'utilisations (global)", class: "block text-xs font-medium text-gray-400 mb-1" %>
        <%= f.number_field :max_uses_total, min: 1, placeholder: "Illimité",
              class: "w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-600 focus:outline-none focus:border-gray-500" %>
      </div>
      <div>
        <%= f.label :max_uses_per_user, "Nb max par utilisateur", class: "block text-xs font-medium text-gray-400 mb-1" %>
        <%= f.number_field :max_uses_per_user, min: 1,
              class: "w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white focus:outline-none focus:border-gray-500" %>
      </div>
    </div>

    <%# Notifications email ── résumé quotidien d'utilisation %>
    <div>
      <%= f.label :notification_emails, "Emails de notification (résumé quotidien d'utilisation)", class: "block text-xs font-medium text-gray-400 mb-1" %>
      <%= f.text_area :notification_emails, rows: 2,
            value: promo_code.notification_emails.join(", "),
            placeholder: "marketing@diet-vision.com, brice@diet-vision.com",
            class: "w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white placeholder-gray-600 focus:outline-none focus:border-gray-500" %>
      <p class="text-[11px] text-gray-600 mt-1">Séparez plusieurs adresses par une virgule. Un email récapitulatif est envoyé chaque jour tant que ce code est utilisé.</p>

      <% unless promo_code.new_record? %>
        <div class="flex items-center gap-3 p-3 rounded-lg border border-gray-700 mt-3" style="background:#0d1117">
          <div class="flex-1">
            <div class="text-xs font-semibold text-white">Tester l'envoi</div>
            <div class="text-[11px] text-gray-500 mt-0.5">Envoie immédiatement le résumé à une adresse de votre choix</div>
          </div>
          <button type="button" onclick="openPromoReportTestModal()"
                  class="flex-shrink-0 px-4 py-2 rounded-lg text-xs font-bold border transition-colors cursor-pointer"
                  style="background:rgba(200,255,0,0.1);color:#C8FF00;border-color:rgba(200,255,0,0.3)">
            📤 Envoyer un test
          </button>
        </div>

        <%# Modal email destinataire %>
        <div id="promo-report-test-modal"
             style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.7);align-items:center;justify-content:center">
          <div style="background:#111827;border:1px solid #374151;border-radius:16px;padding:28px;width:100%;max-width:440px;margin:16px">
            <div class="text-sm font-bold text-white mb-1">📤 Envoyer un résumé test</div>
            <div class="text-xs text-gray-500 mb-5">Envoie le résumé d'utilisation du code <span class="font-mono text-white"><%= promo_code.code %></span> avec les chiffres actuels.</div>

            <label class="block text-xs text-gray-400 mb-1">Email destinataire <span class="text-red-400">*</span></label>
            <input type="email" id="promo-report-test-email"
                   value="<%= current_admin.email %>"
                   placeholder="votre@email.com"
                   class="w-full px-3 py-2.5 rounded-lg text-sm text-white mb-4"
                   style="background:#1f2937;border:1px solid #374151;outline:none;box-sizing:border-box"
                   onfocus="this.style.borderColor='#C8FF00'" onblur="this.style.borderColor='#374151'">

            <div class="flex gap-3 justify-end">
              <button type="button" onclick="closePromoReportTestModal()"
                      class="px-4 py-2 text-xs text-gray-400 rounded-lg transition-colors cursor-pointer"
                      style="background:#1f2937;border:1px solid #374151">
                Annuler
              </button>
              <button type="button" onclick="submitPromoReportTest()"
                      class="px-4 py-2 text-xs font-bold rounded-lg transition-colors cursor-pointer"
                      style="background:#C8FF00;color:#0f172a;border:none">
                Envoyer
              </button>
            </div>
          </div>
        </div>

        <script>
          function openPromoReportTestModal() {
            var modal = document.getElementById('promo-report-test-modal');
            modal.style.display = 'flex';
            setTimeout(function(){ document.getElementById('promo-report-test-email').focus(); }, 100);
          }
          function closePromoReportTestModal() {
            document.getElementById('promo-report-test-modal').style.display = 'none';
          }
          function submitPromoReportTest() {
            var email = document.getElementById('promo-report-test-email').value.trim();
            if (!email) { alert('Veuillez entrer une adresse email.'); return; }
            var f = document.createElement('form');
            f.method = 'POST';
            f.action = '<%= send_report_test_admin_promo_code_path(promo_code) %>';
            var t = document.createElement('input');
            t.type = 'hidden'; t.name = 'authenticity_token';
            t.value = '<%= form_authenticity_token %>';
            var e = document.createElement('input');
            e.type = 'hidden'; e.name = 'test_email'; e.value = email;
            f.appendChild(t); f.appendChild(e);
            document.body.appendChild(f);
            closePromoReportTestModal();
            f.submit();
          }
          document.getElementById('promo-report-test-modal').addEventListener('click', function(ev) {
            if (ev.target === this) closePromoReportTestModal();
          });
        </script>
      <% else %>
        <p class="text-[11px] text-gray-600 italic mt-2">💡 Enregistrez le code pour pouvoir envoyer un test.</p>
      <% end %>
    </div>

    <%# Statut %>
    <div>
      <%= f.label :status, "Statut", class: "block text-xs font-medium text-gray-400 mb-1" %>
      <%= f.select :status,
            [["Actif", "active"], ["Désactivé", "disabled"]],
            { selected: promo_code.status },
            class: "w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white focus:outline-none focus:border-gray-500" %>
    </div>

    <%# Boutons %>
    <div class="flex items-center gap-3 pt-1">
      <%= f.submit promo_code.new_record? ? "Créer le code" : "Enregistrer",
            class: "px-5 py-2 text-sm font-semibold rounded-lg cursor-pointer",
            style: "background:#C8FF00;color:#0a0a0f" %>
      <%= link_to "Annuler", admin_promo_codes_path, class: "px-5 py-2 text-sm text-gray-400 hover:text-white" %>
    </div>

  <% end %>
</div>
