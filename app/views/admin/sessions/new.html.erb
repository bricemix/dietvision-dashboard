      </div>
      <h1 class="text-2xl font-bold">
        <span class="text-white">Diet</span><span style="color:#C8FF00">Vision</span>
      </h1>
      <p class="text-gray-500 text-sm mt-1">Administration</p>
    </div>

    <%# ── Formulaire ─────────────────────────────────────── %>
    <div class="bg-gray-900 rounded-xl border border-gray-800 p-6">

      <% if flash[:alert] %>
        <div class="mb-4 px-3 py-2.5 bg-red-950 border border-red-800 rounded-lg text-red-400 text-sm">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: admin_login_path, method: :post, class: "space-y-4" do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-400 mb-1.5">Email</label>
          <%= f.email_field :email, autocomplete: "email", required: true,
                class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white
                        placeholder-gray-500 text-sm",
                placeholder: "admin@dietvision.app" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-400 mb-1.5">Mot de passe</label>
          <%= f.password_field :password, autocomplete: "current-password", required: true,
                class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white
                        placeholder-gray-500 text-sm",
                placeholder: "••••••••" %>
        </div>
        <%= f.submit "Se connecter",
              class: "w-full py-2.5 btn-primary rounded-lg text-sm cursor-pointer transition-colors" %>
      <% end %>
    </div>

  </div>
</body>
</html>
