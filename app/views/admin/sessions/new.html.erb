<!DOCTYPE html>
<html lang="fr" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>DietVision Admin — Connexion</title>
  <%= csrf_meta_tags %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="h-full bg-gray-950 text-gray-100 flex items-center justify-center">

  <div class="w-full max-w-sm px-6">

    <%# ── Logo + titre ──────────────────────────────────── %>
    <div class="text-center mb-8">
      <div class="flex justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="72" height="72" viewBox="0 0 1024 1024" style="border-radius:18px">
          <rect width="1024" height="1024" rx="220" fill="#111111"/>
          <path d="M160,160 L280,160 M160,160 L160,280" fill="none" stroke="#C8FF00" stroke-width="28" stroke-linecap="round"/>
          <path d="M864,160 L744,160 M864,160 L864,280" fill="none" stroke="#C8FF00" stroke-width="28" stroke-linecap="round"/>
          <path d="M160,864 L280,864 M160,864 L160,744" fill="none" stroke="#C8FF00" stroke-width="28" stroke-linecap="round"/>
          <path d="M864,864 L744,864 M864,864 L864,744" fill="none" stroke="#C8FF00" stroke-width="28" stroke-linecap="round"/>
          <line x1="160" y1="490" x2="864" y2="490" stroke="#C8FF00" stroke-width="8" stroke-opacity="0.18" stroke-dasharray="20,20"/>
          <circle cx="512" cy="512" r="280" fill="none" stroke="#C8FF00" stroke-width="18"/>
          <circle cx="512" cy="512" r="220" fill="#1a1a1a" stroke="#252525" stroke-width="6"/>
          <line x1="460" y1="360" x2="460" y2="664" stroke="#C8FF00" stroke-width="22" stroke-linecap="round"/>
          <line x1="428" y1="360" x2="428" y2="444" stroke="#C8FF00" stroke-width="16" stroke-linecap="round"/>
          <line x1="492" y1="360" x2="492" y2="444" stroke="#C8FF00" stroke-width="16" stroke-linecap="round"/>
          <path d="M428,444 Q460,480 492,444" fill="none" stroke="#C8FF00" stroke-width="16" stroke-linecap="round"/>
          <line x1="564" y1="360" x2="564" y2="664" stroke="#C8FF00" stroke-width="22" stroke-linecap="round"/>
          <path d="M564,360 Q618,430 564,500" fill="#1a1a1a" stroke="#C8FF00" stroke-width="16" stroke-linejoin="round" stroke-linecap="round"/>
          <circle cx="512" cy="522" r="46" fill="#C8FF00"/>
          <circle cx="512" cy="522" r="18" fill="#111111"/>
        </svg>
      </div>
      <h1 class="text-2xl font-bold">
        <span class="text-white">Diet</span><span style="color:#C8FF00">Vision</span>
      </h1>
      <p class="text-gray-500 text-sm mt-1">Administration</p>
    </div>

    <%# ── Formulaire ─────────────────────────────────────── %>
    <div class="bg-gray-900 rounded-xl border border-gray-800 p-6">

      <% if flash[:alert] %>
        <div class="mb-4 px-3 py-2.5 bg-red-950 border border-red-800 rounded-lg text-red-400 text-sm">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: admin_login_path, method: :post, class: "space-y-4" do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-400 mb-1.5">Email</label>
          <%= f.email_field :email, autocomplete: "email", required: true,
                class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white
                        placeholder-gray-500 text-sm",
                placeholder: "admin@dietvision.app" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-400 mb-1.5">Mot de passe</label>
          <%= f.password_field :password, autocomplete: "current-password", required: true,
                class: "w-full px-3 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white
                        placeholder-gray-500 text-sm",
                placeholder: "••••••••" %>
        </div>
        <%= f.submit "Se connecter",
              class: "w-full py-2.5 btn-primary rounded-lg text-sm cursor-pointer transition-colors" %>
      <% end %>
    </div>

  </div>
</body>
</html>
