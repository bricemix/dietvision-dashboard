<% content_for :title, "Notifications push" %>

<div class="max-w-3xl mx-auto">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-white">Notifications push</h1>
    <p class="text-gray-400 text-sm mt-1">Composer et envoyer une notification aux appareils enregistrés (FCM).</p>
  </div>

  <!-- Stats appareils -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
      <div class="text-xs text-gray-500">Appareils total</div>
      <div class="text-2xl font-bold text-white"><%= @total %></div>
    </div>
    <% %w[pro premium vip].each do |p| %>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
        <div class="text-xs text-gray-500"><%= p.upcase %></div>
        <div class="text-2xl font-bold text-white"><%= @by_plan[p].to_i %></div>
      </div>
    <% end %>
  </div>

  <% if @total.zero? %>
    <div class="bg-amber-950/40 border border-amber-900/50 text-amber-300 rounded-xl p-4 mb-6 text-sm">
      Aucun appareil enregistré pour l'instant. Les tokens apparaîtront dès que des utilisateurs
      ouvriront l'app (build avec FCM) et accepteront les notifications.
    </div>
  <% end %>

  <!-- Mes modèles enregistrés (hors formulaire d'envoi) -->
  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5 mb-4">
    <div class="text-sm font-medium text-gray-300 mb-3">Mes modèles enregistrés</div>
    <% if @saved.any? %>
      <div class="flex flex-wrap gap-2 mb-4">
        <% @saved.each do |tpl| %>
          <div class="flex items-center bg-gray-950 border border-gray-700 rounded-lg overflow-hidden">
            <button type="button" data-saved-tpl
              data-title="<%= tpl.title %>" data-body="<%= tpl.body %>"
              class="px-3 py-1.5 text-sm text-gray-200 hover:bg-gray-800 transition-colors"><%= tpl.name %></button>
            <%= button_to "✕", admin_push_destroy_template_path(tpl), method: :delete,
                  form: { onsubmit: "return confirm('Supprimer ce modèle ?');" },
                  class: "px-2.5 py-1.5 text-red-400 hover:bg-red-950/50 border-l border-gray-700 text-xs" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-xs text-gray-500 mb-4">Aucun modèle enregistré. Compose un message ci-dessous puis « Enregistrer comme modèle ».</p>
    <% end %>

    <%= form_with url: admin_push_save_template_path, method: :post, local: true, id: "save-tpl-form",
          class: "flex flex-col sm:flex-row gap-2 sm:items-end" do %>
      <div class="flex-1">
        <label class="block text-xs text-gray-400 mb-1">Enregistrer le message courant comme modèle</label>
        <input type="text" name="name" placeholder="Nom du modèle (ex : Promo annuelle)" maxlength="60"
          class="w-full bg-gray-950 border border-gray-700 rounded-lg px-3 py-2 text-white text-sm focus:border-lime-500 focus:outline-none">
      </div>
      <input type="hidden" name="title" id="save-tpl-title">
      <input type="hidden" name="body"  id="save-tpl-body">
      <button type="submit"
        class="bg-gray-800 hover:bg-gray-700 text-gray-200 text-sm font-medium px-4 py-2 rounded-lg transition-colors whitespace-nowrap">
        💾 Enregistrer comme modèle
      </button>
    <% end %>
  </div>

  <!-- Formulaire d'envoi -->
  <%= form_with url: admin_push_notifications_path, method: :post, local: true,
        class: "bg-gray-900 border border-gray-800 rounded-2xl p-6 space-y-5" do |f| %>

    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1.5">Modèle rapide</label>
      <select id="push-template"
        class="w-full bg-gray-950 border border-gray-700 rounded-lg px-3 py-2.5 text-white focus:border-lime-500 focus:outline-none">
        <option value="">— Choisir un modèle (optionnel) —</option>
        <option value="promo">🎉 Promo annuelle</option>
        <option value="recipes">🥗 Nouvelles recettes</option>
        <option value="report">📊 Bilan prêt</option>
        <option value="reminder">🍽️ Rappel repas</option>
        <option value="motivation">💪 Motivation</option>
        <option value="feature">✨ Nouveauté app</option>
      </select>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1.5">Cible</label>
      <select name="target"
        class="w-full bg-gray-950 border border-gray-700 rounded-lg px-3 py-2.5 text-white focus:border-lime-500 focus:outline-none">
        <option value="all">Tous les appareils (<%= @total %>)</option>
        <option value="plan:pro">Plan Pro (<%= @by_plan["pro"].to_i %>)</option>
        <option value="plan:premium">Plan Premium (<%= @by_plan["premium"].to_i %>)</option>
        <option value="plan:vip">Plan VIP (<%= @by_plan["vip"].to_i %>)</option>
        <option value="plan:starter">Plan Starter (<%= @by_plan["starter"].to_i %>)</option>
        <option value="plan:free">Plan Free (<%= @by_plan["free"].to_i %>)</option>
        <option value="inactive7">Inactifs depuis 7 jours</option>
      </select>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1.5">Titre</label>
      <input type="text" name="title" id="push-title" maxlength="60" required
        placeholder="Ex : Ton bilan hebdo est prêt 🎉"
        class="w-full bg-gray-950 border border-gray-700 rounded-lg px-3 py-2.5 text-white focus:border-lime-500 focus:outline-none">
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1.5">Message</label>
      <textarea name="body" id="push-body" rows="3" maxlength="180" required
        placeholder="Ex : Découvre tes progrès de la semaine dans l'app."
        class="w-full bg-gray-950 border border-gray-700 rounded-lg px-3 py-2.5 text-white focus:border-lime-500 focus:outline-none"></textarea>
    </div>

    <div class="flex items-start gap-2.5 bg-gray-950/60 border border-gray-800 rounded-lg p-3">
      <input type="checkbox" name="auto_translate" id="auto_translate" value="1" checked
        class="mt-0.5 w-4 h-4 rounded border-gray-600 bg-gray-950 text-lime-500 focus:ring-lime-500">
      <label for="auto_translate" class="text-sm text-gray-300 leading-snug">
        🌍 <strong>Traduire automatiquement (IA)</strong> dans la langue de chaque utilisateur (FR/EN/DE/ES/PT).
        <span class="block text-xs text-gray-500">Tu écris dans une seule langue — chacun reçoit la sienne. Sinon, tout le monde reçoit le texte tel quel.</span>
      </label>
    </div>

    <div class="flex items-center justify-between pt-2">
      <p class="text-xs text-gray-500">L'envoi est immédiat et irréversible.</p>
      <button type="submit"
        onclick="return confirm('Envoyer cette notification maintenant ?');"
        class="bg-lime-500 hover:bg-lime-400 text-gray-950 font-semibold px-5 py-2.5 rounded-lg transition-colors">
        Envoyer la notification
      </button>
    </div>
  <% end %>
</div>

<script>
(function () {
  if (window.__dvPushTplBound) return;
  window.__dvPushTplBound = true;
  var T = {
    promo:      { title: "Offre limitée 🎉",        body: "-40% sur l'abonnement annuel, cette semaine seulement. Ne perds pas ta progression !" },
    recipes:    { title: "Nouvelles recettes 🥗",   body: "Des idées de plats adaptés à ton régime t'attendent dans l'app." },
    report:     { title: "Ton bilan est prêt 📊",   body: "Consulte tes progrès de la semaine dans DietVision." },
    reminder:   { title: "N'oublie pas ton repas 🍽️", body: "Scanne ton prochain repas pour rester dans tes objectifs." },
    motivation: { title: "Continue comme ça 💪",    body: "Chaque repas sain te rapproche de ton objectif !" },
    feature:    { title: "Nouveautés dans l'app ✨", body: "Découvre les dernières fonctionnalités de DietVision." }
  };
  document.addEventListener('change', function (e) {
    if (!e.target || e.target.id !== 'push-template') return;
    var t = T[e.target.value];
    if (!t) return;
    var ti = document.getElementById('push-title');
    var bo = document.getElementById('push-body');
    if (ti) ti.value = t.title;
    if (bo) bo.value = t.body;
  });

  // Charger un modèle enregistré dans le formulaire
  document.addEventListener('click', function (e) {
    var b = e.target.closest ? e.target.closest('[data-saved-tpl]') : null;
    if (!b) return;
    var ti = document.getElementById('push-title');
    var bo = document.getElementById('push-body');
    if (ti) ti.value = b.getAttribute('data-title') || '';
    if (bo) bo.value = b.getAttribute('data-body') || '';
  });

  // Au moment d'enregistrer un modèle, copier le titre/message courant
  document.addEventListener('submit', function (e) {
    if (!e.target || e.target.id !== 'save-tpl-form') return;
    var ti = document.getElementById('push-title');
    var bo = document.getElementById('push-body');
    var st = document.getElementById('save-tpl-title');
    var sb = document.getElementById('save-tpl-body');
    if (st) st.value = ti ? ti.value : '';
    if (sb) sb.value = bo ? bo.value : '';
  });
})();
</script>
