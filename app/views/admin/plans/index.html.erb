<% content_for :title, "Offres & Plans" %>

<div class="mb-6 flex items-center justify-between gap-3 flex-wrap">
  <div>
    <p class="text-sm text-gray-500 mt-0.5">Les plans actifs sont visibles immédiatement dans l'app mobile</p>
  </div>
  <div class="flex items-center gap-3">
    <%# Sync globale Stripe %>
    <% syncable = @plans.count { |p| p.price_eur_cents.to_i > 0 } %>
    <%= button_to sync_all_stripe_admin_plans_path, method: :post,
          class: "flex items-center gap-2 px-4 py-2 text-sm font-semibold rounded-lg border cursor-pointer transition-colors",
          style: "background:rgba(99,102,241,0.12);color:#818cf8;border-color:rgba(99,102,241,0.35)",
          data: { turbo_confirm: "Synchroniser #{syncable} plan(s) avec Stripe ? Les anciens prix seront archivés." },
          title: "#{syncable} plan(s) avec prix EUR à synchroniser" do %>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/>
        <path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/>
      </svg>
      Sync Stripe globale
      <span class="text-xs font-normal opacity-70">(<%= syncable %>)</span>
    <% end %>

    <%= link_to new_admin_plan_path,
          class: "flex items-center gap-2 px-4 py-2 text-sm font-semibold rounded-lg cursor-pointer transition-colors",
          style: "background:#C8FF00;color:#0a0a0f" do %>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Nouveau plan
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 gap-4">
  <% @plans.each do |plan| %>
    <div class="bg-gray-900 rounded-xl border border-gray-800 p-5">
      <div class="flex items-start justify-between gap-4">

        <%# Infos plan %>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-base font-bold text-white"><%= plan.name %></span>
            <% if plan.badge.present? %>
              <span class="text-[10px] font-bold px-2 py-0.5 rounded-full"
                    style="background:rgba(200,255,0,0.15);color:#C8FF00;border:1px solid rgba(200,255,0,0.3)">
                <%= plan.badge.upcase %>
              </span>
            <% end %>
            <%# Status badge %>
            <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full <%= plan.active? ? 'bg-green-900/50 text-green-400' : plan.draft? ? 'bg-gray-800 text-gray-500' : 'bg-yellow-900/30 text-yellow-500' %>">
              <%= plan.status.upcase %>
            </span>
          </div>
          <div class="text-2xl font-bold lime"><%= plan.price_formatted %><span class="text-sm text-gray-500 font-normal ml-1">/ <%= plan.frequency_label.downcase %></span></div>
          <% if plan.description.present? %>
            <div class="text-sm text-gray-500 mt-1"><%= plan.description %></div>
          <% end %>

          <%# Email report badge -%>
          <% if plan.email_report_frequency.present? && plan.email_report_frequency != 'never' %>
            <div class="mt-1 flex items-center gap-2">
              <span class="inline-flex items-center gap-1.5 text-[10px] font-bold px-2 py-0.5 rounded-full"
                    style="background:rgba(200,255,0,0.1);color:#C8FF00;border:1px solid rgba(200,255,0,0.25)">
                <span>📧</span>
                <span>Rapport <%= Plan::EMAIL_FREQUENCY_LABELS[plan.email_report_frequency]&.downcase %>
                  <% if plan.email_report_frequency == 'weekly' %>
                    · <%= { 'monday' => 'Lun', 'tuesday' => 'Mar', 'wednesday' => 'Mer',
                            'thursday' => 'Jeu', 'friday' => 'Ven', 'saturday' => 'Sam', 'sunday' => 'Dim'
                           }[plan.email_report_day] || plan.email_report_day %>
                  <% end %>
                </span>
              </span>
            </div>
          <% end %>

          <%# Stripe status -%>
          <div class="mt-1 flex items-center gap-2">
            <% if plan.stripe_price_id.present? %>
              <span class="inline-flex items-center gap-1 text-[10px] text-green-400">
                <span>⚡</span>
                <span class="font-mono text-[9px] text-green-500/70"><%= plan.stripe_price_id %></span>
              </span>
            <% else %>
              <span class="text-[10px] text-gray-600 italic">Pas de Stripe Price ID — cliquer "→ Stripe"</span>
            <% end %>
          </div>

          <%# Prix par devise -%>
          <% if plan.prices.any? %>
            <div class="mt-2 flex flex-wrap gap-1.5">
              <% plan.prices.each do |code, amount| %>
                <span class="inline-flex items-center gap-1 text-[10px] px-2 py-0.5 rounded-full bg-gray-800 border border-gray-700 text-gray-400">
                  <span class="font-semibold text-gray-300"><%= code %></span>
                  <span><%= code.in?(["EUR","USD","GBP","CHF"]) ? "#{(amount.to_i / 100.0).round(2)}" : amount %></span>
                </span>
              <% end %>
              <% unless plan.prices["EUR"].to_i > 0 %>
                <span class="inline-flex items-center gap-1 text-[10px] px-2 py-0.5 rounded-full border font-semibold"
                      style="background:rgba(251,146,60,0.12);border-color:rgba(251,146,60,0.4);color:#fb923c"
                      title="Prix EUR non défini — l'app mobile utilisera le prix USD comme fallback">
                  ⚠ EUR manquant
                </span>
              <% end %>
            </div>
          <% else %>
            <div class="mt-2 flex items-center gap-2">
              <span class="text-xs text-gray-600 italic">Aucun prix natif</span>
              <span class="inline-flex items-center gap-1 text-[10px] px-2 py-0.5 rounded-full border font-semibold"
                    style="background:rgba(251,146,60,0.15);border-color:rgba(251,146,60,0.5);color:#fb923c"
                    title="Aucun prix EUR défini — l'app mobile affichera l'ancien prix USD. Modifiez le plan et entrez un prix EUR.">
                ⚠ Prix EUR manquant
              </span>
            </div>
          <% end %>
        </div>

        <%# Actions %>
        <div class="flex items-center gap-2 flex-shrink-0">
          <%= link_to "Modifier", edit_admin_plan_path(plan),
                class: "px-3 py-1.5 text-xs bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-lg transition-colors" %>

          <%# Bouton Stripe Sync %>
          <% if plan.price_eur_cents.to_i > 0 %>
            <%= button_to sync_stripe_admin_plan_path(plan), method: :post,
                  class: "px-3 py-1.5 text-xs rounded-lg border cursor-pointer transition-colors flex items-center gap-1",
                  style: plan.stripe_price_id.present? ? "background:rgba(99,102,241,0.12);color:#818cf8;border-color:rgba(99,102,241,0.3)" : "background:rgba(99,102,241,0.2);color:#818cf8;border-color:rgba(99,102,241,0.5)",
                  data: { turbo_confirm: plan.stripe_price_id.present? ? "Recréer le prix Stripe pour #{plan.name} ? L'ancien sera archivé." : nil } do %>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3">
                <path d="M4 12a1 1 0 0 1 1-1h10.586l-2.293-2.293a1 1 0 0 1 1.414-1.414l4 4a1 1 0 0 1 0 1.414l-4 4a1 1 0 0 1-1.414-1.414L15.586 13H5a1 1 0 0 1-1-1z"/>
              </svg>
              <%= plan.stripe_price_id.present? ? "Re-sync Stripe" : "→ Stripe" %>
            <% end %>
          <% end %>

          <% if plan.active? %>
            <%= button_to "Désactiver", deactivate_admin_plan_path(plan), method: :post,
                  class: "px-3 py-1.5 text-xs bg-yellow-900/30 hover:bg-yellow-900/50 text-yellow-400 rounded-lg border border-yellow-900/50 cursor-pointer transition-colors" %>
          <% elsif plan.draft? || plan.inactive? %>
            <%= button_to "Activer", activate_admin_plan_path(plan), method: :post,
                  class: "px-3 py-1.5 text-xs rounded-lg border cursor-pointer transition-colors",
                  style: "background:rgba(200,255,0,0.08);color:#C8FF00;border-color:rgba(200,255,0,0.25)" %>
          <% end %>
          <%= button_to "Supprimer", admin_plan_path(plan), method: :delete,
                class: "px-3 py-1.5 text-xs bg-red-950 hover:bg-red-900/60 text-red-400 rounded-lg border border-red-900 cursor-pointer transition-colors",
                data: { turbo_confirm: "Supprimer le plan #{plan.name} ?" } %>
        </div>
      </div>

      <%# Features + Opérateurs %>
      <div class="mt-4 pt-4 border-t border-gray-800 flex flex-wrap gap-6">
        <div class="flex-1 min-w-0">
          <div class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-2">Fonctionnalités</div>
          <% if plan.features.any? %>
            <ul class="space-y-1">
              <% plan.features.first(5).each do |f| %>
                <li class="text-sm text-gray-300 flex items-center gap-1.5">
                  <span style="color:#C8FF00">✓</span> <%= f %>
                </li>
              <% end %>
              <% if plan.features.size > 5 %>
                <li class="text-xs text-gray-600">+<%= plan.features.size - 5 %> autres…</li>
              <% end %>
            </ul>
          <% else %>
            <span class="text-sm text-gray-600">Aucune fonctionnalité définie</span>
          <% end %>
        </div>
        <div>
          <div class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-2">Opérateurs acceptés</div>
          <div class="flex flex-wrap gap-1.5">
            <% plan.operator_labels.each do |op| %>
              <span class="text-xs px-2.5 py-1 bg-gray-800 text-gray-300 rounded-full border border-gray-700"><%= op %></span>
            <% end %>
            <% if plan.operators.empty? %>
              <span class="text-xs text-gray-600">Non définis</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <% if @plans.empty? %>
    <div class="bg-gray-900 rounded-xl border border-gray-800 p-12 text-center">
      <div class="text-gray-600 mb-3">Aucun plan créé</div>
      <%= link_to "Créer le premier plan", new_admin_plan_path, class: "text-sm lime hover:underline" %>
    </div>
  <% end %>
</div>
