<% content_for :title, "Paiements" %>

<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <%= stat_card "Revenus totaux",  format_ariary(@total_revenue), icon_money,   "lime" %>
  <%= stat_card "Revenus (mois)",  format_ariary(@revenue_month), icon_calendar, "lime" %>
  <%= stat_card "En attente",      Payment.pending.count,          icon_clock,   "text-yellow-400" %>
  <%= stat_card "Échoués",         Payment.where(status: "failed").count, icon_x_circle, "text-red-400" %>
</div>

<div class="mb-4 flex items-center justify-between gap-3 flex-wrap">
  <%= form_with url: admin_payments_path, method: :get, class: "flex gap-2 flex-wrap" do |f| %>
    <%= f.select :status,
          [["Tous statuts", ""], ["Succès", "success"], ["En attente", "pending"], ["Échoué", "failed"]],
          { selected: params[:status] },
          class: "px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white" %>
    <%= f.select :provider,
          [["Tous opérateurs", ""], ["Stripe", "stripe"], ["MVola", "mvola"], ["Orange Money", "orange_money"],
           ["Airtel Money", "airtel_money"], ["CinetPay", "cinetpay"], ["MTN", "mtn"],
           ["Orange", "orange"], ["Wave", "wave"]],
          { selected: params[:provider] },
          class: "px-3 py-2 bg-gray-800 border border-gray-700 rounded-lg text-sm text-white" %>
    <%= f.submit "Filtrer",
          class: "px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white text-sm rounded-lg cursor-pointer transition-colors" %>
  <% end %>

  <div class="flex gap-2 flex-wrap">
    <%# Bouton bulk repair Stripe — visible seulement s'il y a des pending Stripe %>
    <% if @pending_stripe_count > 0 %>
      <%= button_to "🔄 Réparer #{@pending_stripe_count} pending Stripe",
            repair_stripe_pending_admin_payments_path,
            method: :post,
            data: { confirm: "Vérifier #{@pending_stripe_count} paiement(s) Stripe en attente auprès de Stripe et activer les plans confirmés ?" },
            class: "px-4 py-2 text-sm rounded-lg border cursor-pointer transition-colors",
            style: "background:rgba(234,179,8,0.1);color:#facc15;border-color:rgba(234,179,8,0.3)" %>
    <% end %>
    <%# Export CSV %>
    <%= link_to "⬇ Export CSV", admin_payments_path(format: :csv, status: params[:status], provider: params[:provider]),
          class: "px-4 py-2 text-sm bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-lg border border-gray-700 transition-colors" %>
  </div>
</div>

<div class="bg-gray-900 rounded-xl border border-gray-800 overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-800 text-xs text-gray-500 uppercase tracking-wide">
        <th class="text-left px-5 py-3 font-medium">Transaction</th>
        <th class="text-left px-4 py-3 font-medium">Utilisateur</th>
        <th class="text-left px-4 py-3 font-medium">Montant</th>
        <th class="text-left px-4 py-3 font-medium">Opérateur</th>
        <th class="text-left px-4 py-3 font-medium">Statut</th>
        <th class="text-left px-4 py-3 font-medium">Date</th>
        <th class="text-right px-5 py-3 font-medium">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-800">
      <% @payments.each do |payment| %>
        <tr class="hover:bg-gray-800/50 transition-colors clickable"
            onclick="window.location='<%= admin_payment_path(payment) %>'">
          <td class="px-5 py-3 font-mono text-xs text-gray-300"><%= payment.transaction_id %></td>
          <td class="px-4 py-3">
            <div class="text-gray-200"><%= payment.user&.name %></div>
            <div class="text-xs text-gray-500"><%= payment.phone_number %></div>
          </td>
          <td class="px-4 py-3 font-semibold text-gray-100"><%= format_ariary(payment.amount) %></td>
          <td class="px-4 py-3"><%= operator_badge(payment.provider) %></td>
          <td class="px-4 py-3"><%= status_badge(payment.status) %></td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= payment.created_at.strftime("%d/%m/%Y %H:%M") %></td>
          <td class="px-5 py-3 text-right">
            <%= link_to "Voir", admin_payment_path(payment),
                  class: "text-xs lime hover:underline",
                  onclick: "event.stopPropagation()" %>
          </td>
        </tr>
      <% end %>
      <% if @payments.empty? %>
        <tr><td colspan="7" class="px-5 py-10 text-center text-gray-600">Aucun paiement</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
<%= render "shared/pagination", pagy: @pagy %>
