<% content_for :title, "Détail paiement" %>

<div class="mb-4">
  <%= link_to "← Retour aux paiements", admin_payments_path,
        class: "text-sm text-gray-500 hover:underline transition-colors" %>
</div>

<div class="max-w-2xl">

  <%# ── Détail transaction ──────────────────────────────── %>
  <div class="bg-gray-900 rounded-xl border border-gray-800 p-6 mb-4">
    <div class="flex items-start justify-between mb-6">
      <div>
        <div class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-1">Transaction</div>
        <div class="font-mono text-lg text-white"><%= @payment.transaction_id %></div>
      </div>
      <div class="text-right">
        <%= status_badge(@payment.status) %>
        <div class="text-2xl font-bold text-white mt-2"><%= format_xof(@payment.amount) %></div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4 text-sm">
      <div>
        <div class="text-gray-500 mb-0.5">Utilisateur</div>
        <%= link_to @payment.user.name, admin_user_path(@payment.user),
              class: "lime hover:underline" %>
        <div class="text-xs text-gray-500"><%= @payment.phone_number %></div>
      </div>
      <div>
        <div class="text-gray-500 mb-0.5">Abonnement</div>
        <div class="text-gray-200"><%= @payment.subscription&.label || "—" %></div>
      </div>
      <div>
        <div class="text-gray-500 mb-0.5">Provider</div>
        <div class="text-gray-200"><%= @payment.provider %></div>
      </div>
      <div>
        <div class="text-gray-500 mb-0.5">Ref. Provider</div>
        <div class="text-gray-200 font-mono text-xs"><%= @payment.provider_ref || "—" %></div>
      </div>
      <div>
        <div class="text-gray-500 mb-0.5">Créé le</div>
        <div class="text-gray-200"><%= @payment.created_at.strftime("%d/%m/%Y à %H:%M") %></div>
      </div>
      <% if @payment.paid_at %>
        <div>
          <div class="text-gray-500 mb-0.5">Payé le</div>
          <div class="text-gray-200"><%= @payment.paid_at.strftime("%d/%m/%Y à %H:%M") %></div>
        </div>
      <% end %>
    </div>

    <% if @payment.status == "pending" %>
      <div class="mt-6 pt-4 border-t border-gray-800 flex flex-wrap gap-3 items-center">
        <% if @payment.provider == "stripe" %>
          <%# Vérification Stripe : interroge l'API Stripe et active le plan si payé %>
          <%= button_to "🔄 Re-vérifier via Stripe", recheck_admin_payment_path(@payment),
                method: :post,
                data: { confirm: "Interroger Stripe pour ce paiement et activer le plan si confirmé ?" },
                class: "px-4 py-2 text-sm rounded-lg border cursor-pointer transition-colors",
                style: "background:rgba(99,102,241,0.15);color:#a5b4fc;border-color:rgba(99,102,241,0.4)" %>
          <% if @payment.provider_ref&.start_with?("cs_") %>
            <span class="text-xs text-gray-500 font-mono">Session: <%= @payment.provider_ref %></span>
          <% else %>
            <span class="text-xs text-red-400">⚠ provider_ref manquant ou invalide</span>
          <% end %>
        <% else %>
          <%# Vérification mobile money (CinetPay, Wave, etc.) %>
          <%= button_to "🔄 Re-vérifier via #{@payment.provider.humanize}", recheck_admin_payment_path(@payment),
                method: :post,
                class: "px-4 py-2 text-sm rounded-lg border cursor-pointer transition-colors",
                style: "background:rgba(234,179,8,0.1);color:#facc15;border-color:rgba(234,179,8,0.3)" %>
        <% end %>
      </div>
    <% end %>

    <% if @payment.status == "success" && @payment.provider == "stripe" %>
      <div class="mt-4 pt-4 border-t border-gray-800">
        <div class="text-xs text-emerald-400 flex items-center gap-1">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Plan activé — expire le <%= @payment.subscription&.expires_at&.strftime("%d/%m/%Y") || "—" %>
        </div>
      </div>
    <% end %>
  </div>

  <%# ── Réponse provider ────────────────────────────────── %>
  <% if @payment.provider_response.present? %>
    <div class="bg-gray-900 rounded-xl border border-gray-800 p-5">
      <div class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-3">Réponse provider</div>
      <pre class="text-xs text-gray-400 font-mono overflow-x-auto whitespace-pre-wrap"><%= JSON.pretty_generate(JSON.parse(@payment.provider_response)) rescue @payment.provider_response %></pre>
    </div>
  <% end %>

</div>
