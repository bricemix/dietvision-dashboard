<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Abonnement <%= @plan_name %> activé — DietVision</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background-color: #f4f4f8; font-family: 'Helvetica Neue', Arial, sans-serif; }
    .wrapper { max-width: 560px; margin: 40px auto; background: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }

    .header { background: #0a0a0f; padding: 32px 40px; text-align: center; }
    .logo-text { font-size: 28px; font-weight: 900; letter-spacing: -1px; }
    .logo-diet { color: #ffffff; }
    .logo-vision { color: #c8ff00; }
    .tagline { color: #4a4a6a; font-size: 13px; margin-top: 6px; }

    .body { padding: 40px; }
    .greeting { font-size: 22px; font-weight: 700; color: #0a0a0f; margin-bottom: 16px; }
    .text { font-size: 15px; color: #4a4a5a; line-height: 1.7; margin-bottom: 20px; }

    .success-box { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 12px;
                   padding: 20px 24px; margin: 24px 0; text-align: center; }
    .success-icon { font-size: 40px; margin-bottom: 12px; }
    .success-title { font-size: 18px; font-weight: 700; color: #14532d; margin-bottom: 8px; }
    .success-date { font-size: 14px; color: #166534; }

    .features { background: #f8f9ff; border-radius: 12px; padding: 24px; margin: 24px 0; }
    .feature { display: flex; align-items: flex-start; margin-bottom: 14px; }
    .feature:last-child { margin-bottom: 0; }
    .feature-icon { font-size: 20px; margin-right: 14px; flex-shrink: 0; margin-top: 1px; }
    .feature-text { font-size: 14px; color: #3a3a4a; line-height: 1.5; }
    .feature-title { font-weight: 700; color: #0a0a0f; display: block; margin-bottom: 2px; }

    .cta-wrap { text-align: center; margin: 32px 0 24px; }
    .cta { display: inline-block; background: #c8ff00; color: #0a0a0f; font-size: 15px;
           font-weight: 800; padding: 14px 36px; border-radius: 100px;
           text-decoration: none; letter-spacing: -0.3px; }

    .footer { background: #f8f8fc; padding: 24px 40px; border-top: 1px solid #eeeef4; text-align: center; }
    .footer-text { font-size: 12px; color: #a0a0b8; line-height: 1.6; }
    .footer-link { color: #7070a0; text-decoration: none; }
  </style>
</head>
<body>
  <div class="wrapper">

    <!-- Header -->
    <div class="header">
      <div class="logo-text">
        <span class="logo-diet">Diet</span><span class="logo-vision">Vision</span>
      </div>
      <div class="tagline">Votre coach nutrition alimenté par l'IA</div>
    </div>

    <!-- Body -->
    <div class="body">
      <p class="greeting">Félicitations, <%= @user.name %> ! 🎉</p>

      <p class="text">
        Votre abonnement DietVision <strong><%= @plan_name %></strong> est maintenant actif.
        Profitez de toutes les fonctionnalités sans limite !
      </p>

      <!-- Success -->
      <div class="success-box">
        <div class="success-icon">✅</div>
        <div class="success-title"><%= @plan_name %> activé avec succès</div>
        <div class="success-date">Valable jusqu'au <%= @expires_at.strftime("%d/%m/%Y") %></div>
      </div>

      <!-- Features — dynamiques selon le plan -->
      <div class="features">
        <div class="feature">
          <span class="feature-icon">📸</span>
          <div class="feature-text">
            <% scan_limit = case @plan_level
                            when "premium" then AppConfig.premium_scan_daily_limit
                            when "pro"     then AppConfig.pro_scan_daily_limit
                            else                AppConfig.starter_scan_daily_limit
                            end %>
            <span class="feature-title"><%= scan_limit %> analyses photo / jour</span>
            Photographiez vos repas et obtenez l'analyse nutritionnelle complète en secondes.
          </div>
        </div>
        <div class="feature">
          <span class="feature-icon">🤖</span>
          <div class="feature-text">
            <% chat_limit = case @plan_level
                            when "premium" then AppConfig.premium_chat_daily_limit
                            when "pro"     then AppConfig.pro_chat_daily_limit
                            else                "illimités"
                            end %>
            <span class="feature-title"><%= chat_limit %> échanges coach IA / jour</span>
            Posez toutes vos questions nutritionnelles à votre coach IA personnel.
          </div>
        </div>
        <div class="feature">
          <span class="feature-icon">📊</span>
          <div class="feature-text">
            <span class="feature-title">Historique & suivi complets</span>
            Consultez votre historique nutritionnel, suivez vos macros et vos progrès.
          </div>
        </div>
        <div class="feature">
          <span class="feature-icon">🔄</span>
          <div class="feature-text">
            <span class="feature-title">Renouvellement automatique</span>
            Votre abonnement se renouvelle automatiquement. Annulable à tout moment.
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="cta-wrap">
        <a href="https://diet-vision.com" class="cta">Accéder à <%= @plan_name %></a>
      </div>

      <p class="text" style="font-size:13px; color:#7070a0; margin-top:12px; margin-bottom:0;">
        Merci pour votre confiance ! Questions ?
        <a href="mailto:<%= AppConfig.get('support_email') %>" style="color:#7070a0;"><%= AppConfig.get('support_email') %></a>
      </p>
    </div>

    <!-- Footer -->
    <div class="footer">
      <p class="footer-text">
        &copy; <%= Date.current.year %> DietVision · <a href="https://diet-vision.com" class="footer-link">diet-vision.com</a>
      </p>
    </div>

  </div>
</body>
</html>
