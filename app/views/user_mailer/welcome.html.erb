<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t("user_mailer.welcome.subject", app: "DietVision") %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background-color: #f4f4f8; font-family: 'Helvetica Neue', Arial, sans-serif; }
    .wrapper { max-width: 560px; margin: 40px auto; background: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }

    /* Header */
    .header { background: #0a0a0f; padding: 32px 40px; text-align: center; }
    .logo-text { font-size: 28px; font-weight: 900; letter-spacing: -1px; }
    .logo-diet { color: #ffffff; }
    .logo-vision { color: #c8ff00; }
    .tagline { color: #4a4a6a; font-size: 13px; margin-top: 6px; }

    /* Body */
    .body { padding: 40px; }
    .greeting { font-size: 22px; font-weight: 700; color: #0a0a0f; margin-bottom: 16px; }
    .text { font-size: 15px; color: #4a4a5a; line-height: 1.7; margin-bottom: 20px; }

    /* Feature list */
    .features { background: #f8f9ff; border-radius: 12px; padding: 24px; margin: 28px 0; }
    .feature { display: flex; align-items: flex-start; margin-bottom: 14px; }
    .feature:last-child { margin-bottom: 0; }
    .feature-icon { font-size: 20px; margin-right: 14px; flex-shrink: 0; margin-top: 1px; }
    .feature-text { font-size: 14px; color: #3a3a4a; line-height: 1.5; }
    .feature-title { font-weight: 700; color: #0a0a0f; display: block; margin-bottom: 2px; }

    /* CTA Button */
    .cta-wrap { text-align: center; margin: 32px 0 24px; }
    .cta { display: inline-block; background: #c8ff00; color: #0a0a0f; font-size: 15px;
           font-weight: 800; padding: 14px 36px; border-radius: 100px;
           text-decoration: none; letter-spacing: -0.3px; }

    /* Plan badge */
    .plan-badge { text-align: center; margin-bottom: 28px; }
    .badge { display: inline-block; background: #f0f0f8; border: 1px solid #e0e0ee;
             color: #7070a0; font-size: 12px; font-weight: 600; padding: 6px 16px;
             border-radius: 100px; letter-spacing: 0.3px; }
    .badge-trial { background: #fffff0; border-color: #e8e800; color: #808000; }

    /* Footer */
    .footer { background: #f8f8fc; padding: 24px 40px; border-top: 1px solid #eeeef4; text-align: center; }
    .footer-text { font-size: 12px; color: #a0a0b8; line-height: 1.6; }
    .footer-link { color: #7070a0; text-decoration: none; }

    /* Divider */
    .divider { height: 1px; background: #eeeef4; margin: 8px 0; }
  </style>
</head>
<body>
  <div class="wrapper">

    <!-- Header -->
    <div class="header">
      <div class="logo-text">
        <span class="logo-diet">Diet</span><span class="logo-vision">Vision</span>
      </div>
      <div class="tagline"><%= t("user_mailer.welcome.tagline") %></div>
    </div>

    <!-- Body -->
    <div class="body">
      <p class="greeting"><%= t("user_mailer.welcome.greeting", name: @user.name) %></p>

      <p class="text"><%= t("user_mailer.welcome.intro") %></p>

      <!-- Features -->
      <div class="features">
        <div class="feature">
          <span class="feature-icon">📸</span>
          <div class="feature-text">
            <span class="feature-title"><%= t("user_mailer.welcome.feature_scan_title") %></span>
            <%= t("user_mailer.welcome.feature_scan_body") %>
          </div>
        </div>
        <div class="feature">
          <span class="feature-icon">🤖</span>
          <div class="feature-text">
            <span class="feature-title"><%= t("user_mailer.welcome.feature_coach_title") %></span>
            <%= t("user_mailer.welcome.feature_coach_body") %>
          </div>
        </div>
        <div class="feature">
          <span class="feature-icon">📊</span>
          <div class="feature-text">
            <span class="feature-title"><%= t("user_mailer.welcome.feature_stats_title") %></span>
            <%= t("user_mailer.welcome.feature_stats_body") %>
          </div>
        </div>
      </div>

      <!-- Plan badge -->
      <% trial_days = AppConfig.trial_period_days %>
      <div class="plan-badge">
        <% if @user.in_trial? && trial_days > 0 %>
          <span class="badge badge-trial">
            <%= t("user_mailer.welcome.trial_badge",
                  days:  trial_days,
                  limit: AppConfig.trial_scan_daily_limit) %>
          </span>
        <% else %>
          <span class="badge">
            <%= t("user_mailer.welcome.free_badge", limit: AppConfig.free_scan_daily_limit) %>
          </span>
        <% end %>
      </div>

      <!-- CTA -->
      <div class="cta-wrap">
        <a href="<%= AppConfig.get('email_app_url').presence || 'https://diet-vision.com' %>" class="cta">
          <%= t("user_mailer.welcome.cta") %>
        </a>
      </div>

      <div class="divider"></div>

      <% support = AppConfig.get('support_email') %>
      <p class="text" style="font-size:13px; color:#7070a0; margin-top:20px; margin-bottom:0;">
        <%= t("user_mailer.welcome.support") %>
        <a href="mailto:<%= support %>" style="color:#7070a0;"><%= support %></a>
      </p>
    </div>

    <!-- Footer -->
    <div class="footer">
      <p class="footer-text">
        <%= t("user_mailer.welcome.footer") %><br>
        &copy; <%= Date.current.year %> DietVision &middot;
        <a href="https://diet-vision.com" class="footer-link">diet-vision.com</a>
      </p>
    </div>

  </div>
</body>
</html>
