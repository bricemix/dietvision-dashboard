<%= t("user_mailer.welcome.subject", app: "DietVision") %>
<%= "=" * 50 %>

<%= t("user_mailer.welcome.greeting", name: @user.name) %>

<%= t("user_mailer.welcome.intro") %>

<%= "-" * 50 %>
<%= t("user_mailer.welcome.features_title") %>
<%= "-" * 50 %>

📸 <%= t("user_mailer.welcome.feature_scan_title") %>
   <%= t("user_mailer.welcome.feature_scan_body") %>

🤖 <%= t("user_mailer.welcome.feature_coach_title") %>
   <%= t("user_mailer.welcome.feature_coach_body") %>

📊 <%= t("user_mailer.welcome.feature_stats_title") %>
   <%= t("user_mailer.welcome.feature_stats_body") %>

<%= "-" * 50 %>
<% trial_days = AppConfig.trial_period_days %>
<% if @user.in_trial? && trial_days > 0 %>
<%= t("user_mailer.welcome.trial_badge", days: trial_days, limit: AppConfig.trial_scan_daily_limit) %>
<% else %>
<%= t("user_mailer.welcome.free_badge", limit: AppConfig.free_scan_daily_limit) %>
<% end %>
<%= "-" * 50 %>

<%= t("user_mailer.welcome.cta") %> : <%= AppConfig.get('email_app_url').presence || 'https://diet-vision.com' %>

<%= "-" * 50 %>

<%= t("user_mailer.welcome.support") %> <%= AppConfig.get('support_email') %>

© <%= Date.current.year %> DietVision · https://diet-vision.com
<%= t("user_mailer.welcome.footer") %>
