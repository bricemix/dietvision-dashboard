<div style="font-family: -apple-system, Arial, sans-serif; max-width: 560px; margin: 0 auto; padding: 24px; color: #1a1a1a;">
  <div style="background:#0a0a0f; border-radius: 12px; padding: 24px; text-align:center; margin-bottom: 20px;">
    <span style="font-size: 20px; font-weight: 800; color: #C8FF00; letter-spacing: 1px;">DietVision</span>
  </div>

  <h1 style="font-size: 18px; margin: 0 0 4px;">Résumé quotidien — code promo</h1>
  <p style="font-size: 13px; color: #666; margin: 0 0 20px;"><%= @date.strftime("%d/%m/%Y") %></p>

  <div style="background:#f4f4f6; border-radius: 10px; padding: 16px; margin-bottom: 16px;">
    <div style="font-family: monospace; font-weight: 700; font-size: 22px; letter-spacing: 2px; margin-bottom: 4px;">
      <%= @promo_code.code %>
    </div>
    <div style="font-size: 13px; color: #555;">
      <%= @promo_code.discount_label %> ·
      <span style="text-transform: uppercase; font-weight: 600;"><%= @promo_code.effective_status %></span>
      <% if @promo_code.expires_at %>
        · expire le <%= @promo_code.expires_at.strftime("%d/%m/%Y") %>
      <% end %>
    </div>
  </div>

  <table width="100%" style="border-collapse: collapse; margin-bottom: 20px;">
    <tr>
      <td style="width:50%; padding: 12px; background:#f4f4f6; border-radius: 10px 0 0 10px; text-align:center;">
        <div style="font-size: 28px; font-weight: 800; color: #0a0a0f;"><%= @today_unique %></div>
        <div style="font-size: 11px; color: #666; text-transform: uppercase;">Utilisateur(s) — aujourd'hui</div>
      </td>
      <td style="width:2px;"></td>
      <td style="width:50%; padding: 12px; background:#f4f4f6; border-radius: 0 10px 10px 0; text-align:center;">
        <div style="font-size: 28px; font-weight: 800; color: #0a0a0f;"><%= @today_count %></div>
        <div style="font-size: 11px; color: #666; text-transform: uppercase;">Utilisation(s) — aujourd'hui</div>
      </td>
    </tr>
  </table>

  <div style="font-size: 13px; color: #444; padding: 12px 16px; border: 1px solid #e5e5e5; border-radius: 10px;">
    Depuis la création du code : <strong><%= @total_uses %></strong> utilisation(s) au total,
    par <strong><%= @total_unique %></strong> utilisateur(s) unique(s).
  </div>

  <p style="font-size: 11px; color: #999; margin-top: 24px; text-align: center;">
    Vous recevez cet email car cette adresse est configurée pour le suivi du code
    <strong><%= @promo_code.code %></strong> dans le dashboard DietVision.
  </p>
</div>
