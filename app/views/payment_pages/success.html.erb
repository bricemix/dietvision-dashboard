<!DOCTYPE html>
<%
  locale = params[:locale].to_s
  locale = 'fr' unless %w[fr en de es pt].include?(locale)

  translations = {
    'fr' => { title: 'Paiement r&eacute;ussi', subtitle: 'r&eacute;ussi', desc: "Votre abonnement DietVision est en cours d'activation.", step1: "Fermez cette page et retournez dans l'application DietVision", step2: "Appuyez sur <strong>&laquo; J'ai pay&eacute; &mdash; Confirmer &raquo;</strong> dans l'app", step3: 'Profitez de toutes les fonctionnalit&eacute;s Premium !', email: "Un email de confirmation vous a &eacute;t&eacute; envoy&eacute;.<br>L'activation peut prendre quelques secondes.", ref: 'R&eacute;f&eacute;rence', lang: 'fr' },
    'en' => { title: 'Payment successful', subtitle: 'successful', desc: 'Your DietVision subscription is being activated.', step1: 'Close this page and go back to the DietVision app', step2: 'Tap <strong>&ldquo;I paid &mdash; Confirm&rdquo;</strong> in the app', step3: 'Enjoy all Premium features!', email: 'A confirmation email has been sent to you.<br>Activation may take a few seconds.', ref: 'Reference', lang: 'en' },
    'de' => { title: 'Zahlung erfolgreich', subtitle: 'erfolgreich', desc: 'Ihr DietVision-Abonnement wird gerade aktiviert.', step1: 'Schlie&szlig;en Sie diese Seite und kehren Sie zur DietVision-App zur&uuml;ck', step2: 'Tippen Sie auf <strong>&bdquo;Ich habe bezahlt &mdash; Best&auml;tigen&ldquo;</strong> in der App', step3: 'Genie&szlig;en Sie alle Premium-Funktionen!', email: 'Eine Best&auml;tigungs-E-Mail wurde an Sie gesendet.<br>Die Aktivierung kann einige Sekunden dauern.', ref: 'Referenz', lang: 'de' },
    'es' => { title: 'Pago exitoso', subtitle: 'exitoso', desc: 'Tu suscripci&oacute;n a DietVision se est&aacute; activando.', step1: 'Cierra esta p&aacute;gina y vuelve a la aplicaci&oacute;n DietVision', step2: 'Toca <strong>&laquo;Pagu&eacute; &mdash; Confirmar&raquo;</strong> en la app', step3: '&iexcl;Disfruta de todas las funciones Premium!', email: 'Te hemos enviado un correo de confirmaci&oacute;n.<br>La activaci&oacute;n puede tardar unos segundos.', ref: 'Referencia', lang: 'es' },
    'pt' => { title: 'Pagamento bem-sucedido', subtitle: 'bem-sucedido', desc: 'Sua assinatura do DietVision est&aacute; sendo ativada.', step1: 'Feche esta p&aacute;gina e volte para o aplicativo DietVision', step2: 'Toque em <strong>&laquo;Paguei &mdash; Confirmar&raquo;</strong> no app', step3: 'Aproveite todos os recursos Premium!', email: 'Um e-mail de confirma&ccedil;&atilde;o foi enviado para voc&ecirc;.<br>A ativa&ccedil;&atilde;o pode levar alguns segundos.', ref: 'Refer&ecirc;ncia', lang: 'pt' },
  }
  t = translations[locale]
%>
<html lang="<%= t[:lang] %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DietVision &mdash; <%= t[:title] %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0A0A0F; color: #fff; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px; }
    .card { background: #1A1A2E; border: 1px solid #2A2A3E; border-radius: 24px; padding: 48px 32px; max-width: 420px; width: 100%; text-align: center; }
    .icon { width: 80px; height: 80px; background: rgba(0,255,136,0.12); border: 1.5px solid rgba(0,255,136,0.4); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; font-size: 36px; }
    h1 { font-size: 26px; font-weight: 900; margin-bottom: 12px; letter-spacing: -0.5px; }
    h1 span { color: #00FF88; }
    p { color: #94A3B8; font-size: 15px; line-height: 1.6; margin-bottom: 32px; }
    .steps { background: #0A0A0F; border-radius: 14px; padding: 16px; margin: 24px 0; text-align: left; }
    .step { display: flex; align-items: flex-start; gap: 12px; padding: 8px 0; }
    .step-num { background: rgba(0,255,136,0.15); color: #00FF88; font-weight: 800; font-size: 12px; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px; }
    .step-text { font-size: 13px; color: #CBD5E1; line-height: 1.4; }
    .note { font-size: 12px; color: #64748B; margin-top: 16px; }
  </style>
</head>
<body>
  <div class="card">
    <div class="icon">&#127881;</div>
    <h1>&#x2714; <span><%= t[:title] %></span></h1>
    <p><%= t[:desc] %></p>
    <div class="steps">
      <div class="step"><div class="step-num">1</div><div class="step-text"><%= t[:step1] %></div></div>
      <div class="step"><div class="step-num">2</div><div class="step-text"><%= t[:step2].html_safe %></div></div>
      <div class="step"><div class="step-num">3</div><div class="step-text"><%= t[:step3] %></div></div>
    </div>
    <p style="font-size:13px; color:#64748B;"><%= t[:email].html_safe %></p>
    <% if @session_id.present? %><p class="note"><%= t[:ref] %> : <%= @session_id[0..15] %>...</p><% end %>
  </div>
</body>
</html>
